# Samsung Frame TV Art Manager — Environment Variables
#
# Copy this file to .env and customize for your setup.
# Only TV_IPS is required; everything else has sensible defaults.

# ─── Required ────────────────────────────────────────────────────────────────

# Comma-separated list of TV IP addresses
# Example: TV_IPS=192.168.1.100,192.168.1.101
TV_IPS=192.168.1.100

# ─── Core Settings ───────────────────────────────────────────────────────────

# How often to check and sync artwork (minutes)
# Default: 5
# SYNC_INTERVAL_MINUTES=5

# Client identity for WebSocket handshake.
# A stable name prevents Allow/Deny popups on reconnect.
# Default: Frame Art Manager
# CLIENT_NAME=Frame Art Manager

# Matte/border style for uploaded artwork.
# Format: {style}_{color} or "none" for full-screen.
#
# Styles: modernthin, modern, modernwide, flexible, shadowbox,
#         panoramic, triptych, mix, squares
# Colors: black, neutral, antique, warm, polar, sand, seafoam, sage,
#         burgandy, navy, apricot, byzantine, lavender, redorange,
#         skyblue, turquoise
#
# Examples: shadowbox_polar, modern_apricot, none
# Default: none
# MATTE_STYLE=none

# Log level: debug, info, warn, error
# Default: info
# LOG_LEVEL=info

# ─── Cleanup ─────────────────────────────────────────────────────────────────

# Remove images on TV that aren't tracked by this service.
# Default: false
# REMOVE_UNKNOWN_IMAGES=false

# ─── Wake-on-LAN ─────────────────────────────────────────────────────────────

# MAC address for Wake-on-LAN (optional, wakes sleeping TVs).
# TV_MAC=AA:BB:CC:DD:EE:FF

# ─── REST Gate ───────────────────────────────────────────────────────────────

# Enable the Silent REST Gate (probes port 8001 /ms/art before connecting).
# This prevents popups when the TV is running Netflix/YouTube, but may not
# work on all firmware versions. If your TV always returns 404, leave disabled.
# Default: false
# ENABLE_REST_GATE=false

# ─── Slideshow ───────────────────────────────────────────────────────────────

# DEFAULT BEHAVIOR (if none of these are set):
#   The script preserves and restores your TV's current slideshow settings.
#
# OVERRIDE BEHAVIOR (if any of these are set):
#   The script controls slideshow via these variables.

# SLIDESHOW_ENABLED=true
# SLIDESHOW_INTERVAL=15     # minutes (e.g. 3, 15, 60, 720, 1440)
# SLIDESHOW_TYPE=shuffle     # shuffle or sequential

# ─── Brightness ──────────────────────────────────────────────────────────────

# Option 1: Manual brightness (fixed value, applied every sync cycle)
# BRIGHTNESS=5

# Option 2: Solar brightness (automatic, based on sun position)
# Note: Solar takes precedence over manual if both are set.
# SOLAR_BRIGHTNESS_ENABLED=true
# LOCATION_LATITUDE=42.3601
# LOCATION_LONGITUDE=-71.0589
# LOCATION_TIMEZONE=America/New_York
# BRIGHTNESS_MIN=2          # brightness when sun is below horizon
# BRIGHTNESS_MAX=10         # brightness when sun is at zenith

# ─── Auto-Off ────────────────────────────────────────────────────────────────

# Automatically turn off TVs in art mode at a specific time.
# TVs being used for other content (HDMI, apps) are left alone.
# Requires LOCATION_TIMEZONE to be set.

# AUTO_OFF_TIME=22:00        # 24-hour format
# AUTO_OFF_GRACE_HOURS=2     # hours after AUTO_OFF_TIME to keep trying

# ─── Ownership & Permissions (Docker) ────────────────────────────────────────
#
# PUID and PGID ensure the folders created on the host have the correct
# permissions for your user.
# PUID=1000
# PGID=1000

# ─── Paths ───────────────────────────────────────────────────────────────────

# ARTWORK_DIR=/data/frame-tv-art-manager/artwork
# TOKEN_DIR=/data/frame-tv-art-manager/tokens
